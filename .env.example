# Required for auth and cloud project storage
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Recommended in deployed environments so provider secrets stay off the client
VITE_AI_PROXY_URL=

# Optional local-only fallbacks for direct browser calls
VITE_GOOGLE_API_KEY=
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=
